# ════════════════════════════════════════════════════════════════════════════════
# AI Voice Call Backend — Environment Variables
# Copy to .env and fill in your real credentials.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# Public URL SignalWire will POST webhooks to.
# Use ngrok in development: ngrok http 8000  → paste the https URL here.
APP_BASE_URL=https://your-ngrok-url.ngrok.io

DEBUG=false
LOG_LEVEL=INFO

# Set to "false" to manage the agent worker yourself (separate terminal)
AUTO_START_AGENT=true

# Which service actually places the outbound PSTN call:
#   "signalwire"  → SignalWire REST API dials out, hits /webhooks/swml/{call_id},
#                   which bridges into the LiveKit room. Uses the AMD / voicemail /
#                   webhook pipeline in services/signalwire + api/routes/webhooks.py.
#   "livekit_sip" → LiveKit dials out directly via LIVEKIT_SIP_TRUNK_ID, bypassing
#                   SignalWire's REST API and all webhook/AMD logic entirely.
# If you have SignalWire credentials configured below, you almost certainly want
# "signalwire" here — leaving this unset silently falls back to "livekit_sip" and
# none of your SignalWire webhook code will ever run.
TELEPHONY_PROVIDER=signalwire

# ── SignalWire ────────────────────────────────────────────────────────────────
# Found in your SignalWire dashboard → API Credentials
SIGNALWIRE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SIGNALWIRE_API_TOKEN=PTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com

# The phone number to call FROM (must be a SignalWire number you own)
SIGNALWIRE_FROM_NUMBER=+15551234567

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Found in LiveKit Cloud dashboard → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hosted LiveKit phone number to dial FROM (bought via LiveKit dashboard →
# Telephony → Phone numbers). LiveKit is the carrier directly — no separate
# outbound trunk or carrier auth needed. Takes priority over LIVEKIT_SIP_TRUNK_ID
# below when set. This is the simplest/recommended outbound path.
LIVEKIT_SIP_NUMBER=

# Required if using a bring-your-own-carrier outbound SIP trunk instead of
# LIVEKIT_SIP_NUMBER (configure the trunk in LiveKit dashboard → Telephony → SIP trunks)
LIVEKIT_SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxxxxxx

# The SIP domain where LiveKit receives inbound SIP calls.
# Found in LiveKit dashboard → SIP → Inbound → SIP URI
# e.g. sip.livekit.cloud  or  xxxx.pstn.livekit.cloud
LIVEKIT_SIP_URI=sip.livekit.cloud

# ── Deepgram ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── ElevenLabs ───────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice ID — browse at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/calls.db

# ── AI Agent Behavior ─────────────────────────────────────────────────────────
AGENT_SYSTEM_PROMPT=You are a professional AI voice assistant making outbound phone calls on behalf of a company. Be polite, concise, and natural. Listen carefully and respond appropriately. Keep responses short — no more than 2-3 sentences unless detailed information is needed.

AGENT_INITIAL_GREETING=Hello! This is an AI assistant calling. I hope I'm not catching you at a bad time. How are you today?

AGENT_VOICEMAIL_MESSAGE=Hello, we tried to reach you but were unable to connect. We will try again at a more convenient time. Thank you and have a wonderful day.

# Optional: URL to a pre-recorded voicemail MP3. If empty, TTS is used.
VOICEMAIL_AUDIO_URL=

# ── Call constraints ──────────────────────────────────────────────────────────
MAX_CALL_DURATION_SECONDS=600
AMD_TIMEOUT_SECONDS=30
