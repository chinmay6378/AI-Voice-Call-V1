# ════════════════════════════════════════════════════════════════════════════════
# AI Voice Call Backend — Environment Variables
#
# Copy this file to .env and fill in your real credentials:
#   cp .env.example .env
#
# NEVER commit .env to version control (it's already in .gitignore).
#
# Note: once the app is running, most of these can ALSO be edited from the
# Settings page in the web UI — those edits are saved to the database and
# take priority over this file on every future restart. Treat the UI as the
# source of truth once you've started using it; this file is just what a
# fresh install boots up with.
# ════════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# Public URL this app is reachable at. Only required if you use the
# SignalWire provider below (SignalWire needs a public URL to POST webhooks
# to). Not needed for the LiveKit-native provider.
# For local development with SignalWire, use ngrok: `ngrok http 8000`, then
# paste the https URL here.
APP_BASE_URL=http://localhost:8000

DEBUG=false
LOG_LEVEL=INFO

# Runs the LiveKit agent worker as a child process of this same server.
# Set to "false" only if you're running `python -m services.livekit.agent start`
# yourself in a separate terminal/process/container.
AUTO_START_AGENT=true

# Which service places the outbound PSTN call:
#   "livekit_sip" → LiveKit dials out directly via a SIP trunk (Option A below).
#                   Simple, no webhooks, works with any SIP-trunk-capable
#                   carrier (Twilio, Telnyx, etc). Recommended.
#   "signalwire"  → SignalWire's REST API dials out, then bridges the call
#                   into LiveKit via a webhook (Option B below). Includes
#                   answering-machine detection via SignalWire's platform.
TELEPHONY_PROVIDER=livekit_sip

# ── LiveKit (always required — hosts the AI agent regardless of provider) ────
# Found in LiveKit Cloud dashboard → Settings → API Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ══ Option A — LiveKit-native SIP (TELEPHONY_PROVIDER=livekit_sip) ═══════════
#
# Outbound: create a SIP trunk in LiveKit dashboard → Telephony → SIP trunks
# (Outbound direction), pointing at your carrier (Twilio, Telnyx, etc — see
# README.md for a full Twilio walkthrough). Then set ONE of:

# Hosted LiveKit phone number to dial FROM (bought via LiveKit dashboard →
# Telephony → Phone numbers). NOTE: as of writing, LiveKit's hosted numbers
# only support INBOUND calling — outbound still requires LIVEKIT_SIP_TRUNK_ID
# below to be set too (LiveKit's API rejects the call otherwise even if this
# is set). Leave blank if you don't have a hosted number.
LIVEKIT_SIP_NUMBER=

# Outbound SIP trunk ID from LiveKit dashboard → Telephony → SIP trunks.
LIVEKIT_SIP_TRUNK_ID=ST_xxxxxxxxxxxxxxxxxxxx

# Inbound: create a SIP trunk in LiveKit dashboard → Telephony → SIP trunks
# (Inbound direction) with your number(s), then set its ID here. After
# changing this, call POST /call/inbound/setup (or use the Settings UI's
# "Apply Inbound Rule" button) to (re)create the dispatch rule that routes
# inbound calls to the agent. Leave blank to accept inbound calls on any
# trunk in the project.
LIVEKIT_INBOUND_SIP_TRUNK_ID=

# ══ Option B — SignalWire (TELEPHONY_PROVIDER=signalwire) ════════════════════
# Found in your SignalWire dashboard → API Credentials
SIGNALWIRE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SIGNALWIRE_API_TOKEN=PTxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SIGNALWIRE_SPACE_URL=yourspace.signalwire.com

# The phone number to call FROM (must be a SignalWire number you own)
SIGNALWIRE_FROM_NUMBER=+15551234567

# The SIP domain where LiveKit receives inbound SIP calls — SignalWire bridges
# the answered call here. Found in LiveKit dashboard → SIP → Inbound → SIP URI
# e.g. sip.livekit.cloud  or  xxxx.pstn.livekit.cloud
LIVEKIT_SIP_URI=sip.livekit.cloud

# ── Deepgram (speech-to-text) ─────────────────────────────────────────────────
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPGRAM_MODEL=nova-2
DEEPGRAM_LANGUAGE=en-US

# ── Groq (LLM, OpenAI-compatible API) ─────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── ElevenLabs (text-to-speech) ───────────────────────────────────────────────
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Voice ID — browse at elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# ── Database ─────────────────────────────────────────────────────────────────
# Default SQLite is fine for a single-instance/POC deployment. The ./data
# directory is created automatically if it doesn't exist.
DATABASE_URL=sqlite+aiosqlite:///./data/calls.db

# ── AI Agent Identity ─────────────────────────────────────────────────────────
AGENT_NAME=Alex
COMPANY_NAME=Your Company Name

# ── AI Agent Behavior ─────────────────────────────────────────────────────────
# {agent_name}, {company_name}, {customer_name} placeholders are filled in per-call.
AGENT_INITIAL_GREETING=Hello! This is {agent_name} calling on behalf of {company_name}. I hope I'm not catching you at a bad time. How are you today?

AGENT_VOICEMAIL_MESSAGE=Hello, we tried to reach you but were unable to connect. We will try again at a more convenient time. Thank you and have a wonderful day.

# Optional: URL to a pre-recorded voicemail MP3. If empty, TTS is used.
VOICEMAIL_AUDIO_URL=

# ── Call constraints ──────────────────────────────────────────────────────────
MAX_CALL_DURATION_SECONDS=600
AMD_TIMEOUT_SECONDS=30
